# Ignore macOS system files
.DS_Store
# Ignore Windows thumbnail caches
Thumbs.db

# --- IDEs & EDITORS ---
# VS Code
.vscode/
# Android Studio / IntelliJ
.idea/
*.iml
*.iws
*.ipr
